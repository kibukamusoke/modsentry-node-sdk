{
  "name": "@modsentry/sdk",
  "version": "0.1.0",
  "description": "Official JavaScript SDK for ModSentry moderation APIs",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate:sdk": "npm --prefix ../modsentry-api run openapi:npm",
    "build": "npm run generate:sdk && tsup src/index.ts --dts --format esm,cjs --clean",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "axios": "^1.8.4"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.5.3"
  }
}
